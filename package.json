{
  "name": "moral-aps",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:persoonlijk": "npm --prefix \"apps/persoonlijke-integriteitsmeting\" run dev",
    "dev:organisatie": "npm --prefix \"apps/organisatie-lakmoesproef\" run dev",
    "dev:crossroads": "npm --prefix \"apps/moral-maps-2-crossroads\" run dev",
    "build:persoonlijk": "npm --prefix \"apps/persoonlijke-integriteitsmeting\" run build",
    "build:organisatie": "npm --prefix \"apps/organisatie-lakmoesproef\" run build",
    "build:crossroads": "npm --prefix \"apps/moral-maps-2-crossroads\" run build",
    "build:all": "npm run build && npm run build:persoonlijk && npm run build:organisatie && npm run build:crossroads",
    "lint:persoonlijk": "npm --prefix \"apps/persoonlijke-integriteitsmeting\" run lint",
    "lint:organisatie": "npm --prefix \"apps/organisatie-lakmoesproef\" run lint",
    "lint:crossroads": "npm --prefix \"apps/moral-maps-2-crossroads\" run lint",
    "lint:all": "npm run lint:persoonlijk && npm run lint:organisatie && npm run lint:crossroads"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4"
  }
}
